# Application
APP_NAME=Memory Server
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8899

# ParadeDB / PostgreSQL (BM25 + relational)
DATABASE_URL=postgresql://memory:memory@localhost:5433/memory_server
# 本地一般为 false；云上若强制 SSL 再设为 true
DATABASE_SSL=false

# Docker 数据目录（绑定到宿主机磁盘；可改为挂载盘绝对路径，如 /mnt/data/memory-server）
# DATA_DIR=./data

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_MEM0_COLLECTION=mem0_global_memory
VECTOR_SIZE=1536

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 走 SOCKS 时请写 socks5://127.0.0.1:端口（勿用 socks://；程序也会把 socks:// 自动改成 socks5://）
# ALL_PROXY=socks5://127.0.0.1:10808
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Mem0 Configuration
MEM0_API_KEY=
MEM0_SEARCH_MSG_LIMIT=5
MEM0_HYBRID_VECTOR_WEIGHT=0.7
MEM0_HYBRID_BM25_WEIGHT=0.3
# 检索阈值与融合过滤（由服务端配置；请求体不再传）
MEM0_SEARCH_VECTOR_MIN_SCORE=0
# MEM0_SEARCH_LEXICAL_MIN_SCORE=
# MEM0_SEARCH_MIN_FUSION_SCORE=

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Internal service clients
# Example:
# {"svc-agent":{"secret":"replace-me","namespaces":["team-a"]}}
SERVICE_CLIENTS_JSON={}
