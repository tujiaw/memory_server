# Application
APP_NAME=Memory Server
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8899

# PostgreSQL（仅关系数据：subjects、service_clients 等）
DATABASE_URL=postgresql://memory:memory@localhost:5433/memory_server
DATABASE_SSL=false

# Docker 数据目录
# DATA_DIR=./data

# Elasticsearch（mem0 向量 + BM25 共用索引；与 docker-compose 中 ELASTIC_PASSWORD 一致）
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_INDEX=mem0_memory
ELASTICSEARCH_VERIFY_CERTS=false
VECTOR_SIZE=1536

# 阿里云 ES 示例：host 带 https，端口 9200，VERIFY_CERTS=true，账号密码用控制台凭证
# ELASTICSEARCH_HOST=https://es-cn-xxxx.elasticsearch.aliyuncs.com
# ELASTICSEARCH_PORT=9200
# ELASTICSEARCH_VERIFY_CERTS=true

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# ALL_PROXY=socks5://127.0.0.1:10808
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Mem0 Configuration
MEM0_API_KEY=
MEM0_SEARCH_MSG_LIMIT=5
MEM0_HYBRID_VECTOR_WEIGHT=0.7
MEM0_HYBRID_BM25_WEIGHT=0.3
MEM0_SEARCH_VECTOR_MIN_SCORE=0
# MEM0_SEARCH_BM25_MIN_SCORE=
# MEM0_SEARCH_MIN_HYBRID_SCORE=

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

SERVICE_CLIENTS_JSON={}
