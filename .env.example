# Application
APP_NAME=Memory Server
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8899

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
VECTOR_SIZE=1536

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=memory_server
MONGO_COLLECTION_USERS=users
MONGO_COLLECTION_SUBJECTS=subjects
MONGO_COLLECTION_SERVICE_CLIENTS=service_clients
MONGO_COLLECTION_SERVICE_TOKENS=service_tokens

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Mem0 Configuration
MEM0_API_KEY=
MEM0_SEARCH_MSG_LIMIT=5
# Leave these empty to disable graph memory outside Docker Compose.
# Docker Compose will inject its own internal Neo4j connection values.
NEO4J_URL=
NEO4J_USERNAME=
NEO4J_PASSWORD=
MEM0_GRAPH_CUSTOM_PROMPT=

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Internal service clients
# Example:
# {"svc-agent":{"secret":"replace-me","namespaces":["team-a"]}}
SERVICE_CLIENTS_JSON={}
